	public function kyc(){
		//DATA PENGAJUAN		
		$json1 =file_get_contents(realpath(".").'/json/DATA_PENGAJUAN_20210419033207.json');
		
		//DATA SPAJ
		$json2 = file_get_contents(realpath(".").'/json/SPAJ_JSON_20210419033207.json');
	
		$decode1=json_decode($json1,true);
		$decode2=json_decode($json2,true);
