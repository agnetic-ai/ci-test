	private function convertStringTonumberMonth($month)
	{
		$map = array( '12' => 'Desember', '11' => 'November', '10' => 'Oktober', '09' => 'September', '08' => 'Agustus', '07' => 'Juli', '06' => 'Juni', '05' => 'Mei', '04' => 'April', '03' => 'Maret', '02' => 'Februari', '01' => 'Januari');
		$returnValue = '';
			foreach ($map as $roman => $string) {

				if($month == $string){
					$returnValue .= $roman;
					break;
				}
			}

		return $returnValue;
	}
	
