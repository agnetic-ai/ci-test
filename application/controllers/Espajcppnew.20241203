				'No'=>'no2',
				''=>''
				);
				$content=str_replace("{".$yes2[$val]."}","V",$content);
				unset($yes2[$val]);
				foreach($yes2 as $yes2_key=>$yes2_val){
					$content=str_replace("{".$yes2_val."}","",$content);
				}
				
