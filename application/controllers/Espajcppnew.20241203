					foreach($assets1 as $assets1_key=>$assets1_val){
						$content=str_replace("{".$assets1_val."}","",$content);
					}
				}
					
			// }

			if($val['name'] == 'policy_holder_income_company'){
				$holderIncome=array(
				'<100Jt'=>'policy_holder_income_company1',
				'100Juta-1Milyar'=>'policy_holder_income_company2',
				'>1Milyar-10Milyar'=>'policy_holder_income_company3',
				'>10Milyar-100Milyar'=>'policy_holder_income_company4',
				'>100Milyar'=>'policy_holder_income_company5',
				''=>''
				);	
				$content=str_replace("{".$holderIncome[$val['value']]."}","V",$content);
				unset($holderIncome[$val['value']]);
				foreach($holderIncome as $holderIncome_key=>$holderIncome_val){
					$content=str_replace("{".$holderIncome_val."}","",$content);
				}	
				
			}

			if($val['name'] == 'premium_payer_other_income3'){
				$premium_payer_other_income=array(
					'Tidak ada'=>'premium_payer_other_income1',
					'Hasil Usaha'=>'premium_payer_other_income2',
					'Warisan'=>'premium_payer_other_income3',
					'Komisi/Honor'=>'premium_payer_other_income4',
					''=>'premium_payer_other_income5'
				);
				$content=str_replace("{".$premium_payer_other_income[$val['value']]."}","V",$content);
				unset($premium_payer_other_income[$val['value']]);
				foreach($premium_payer_other_income as $premium_payer_other_income_key=>$premium_payer_other_income_val){
					$content=str_replace("{".$premium_payer_other_income_val."}","",$content);
				}	
				
			}

			if($val['name'] == 'premium_payer_other_income_value3'){
				$premium_payer_other_income=array(
					'<=100 Juta'=>'premium_payer_other_income_value1',
					'>100 Juta sd 250 Juta'=>'premium_payer_other_income_value2',
					'>250 Juta sd 500 Juta'=>'premium_payer_other_income_value3',
					'>500 Juta sd 1 Miliar'=>'premium_payer_other_income_value4',
					'>1 Miliar sd 10 Miliar'=>'premium_payer_other_income_value5',
					'>10 Miliar'=>'premium_payer_other_income_value6',
					''=>'premium_payer_other_income_value7'
				);
				$premium_payer_other_income[$val['value']]=isset($premium_payer_other_income[$val['value']]) ? $premium_payer_other_income[$val['value']]:"";
				
				$content=str_replace("{".$premium_payer_other_income[$val['value']]."}","V",$content);
				unset($premium_payer_other_income[$val['value']]);
				foreach($premium_payer_other_income as $premium_payer_other_income_key=>$premium_payer_other_income_val){
					$content=str_replace("{".$premium_payer_other_income_val."}","",$content);
				}	
				
			}

			// * Note
			if($val['name'] == 'customer_type1'){
				if($val['value'] == 'Individu'){
					$is_individu=true;
					
				}
			}
			
			if($val['name'] == 'insurance_purpose8'){
				$insurance_purpose8=array(
					'Proteksi'=>'insurance_purpose8',
					'Investasi'=>'insurance_purpose9',
					'Pendidikan'=>'insurance_purpose10',
					'Pensiun'=>'insurance_purpose10',
					'Tujuan Usaha'=>'insurance_purpose10',
					'Lain-lain'=>'insurance_purpose10',
					''=>''
				);	
				$content=str_replace("{".$insurance_purpose8[$val['value']]."}","V",$content);
				unset($insurance_purpose8[$val['value']]);
				foreach($insurance_purpose8 as $insurance_purpose8_key=>$insurance_purpose8_val){
					$content=str_replace("{".$insurance_purpose8_val."}","",$content);
				}

				if($val['value'] == "Pendidikan" || $val['value'] == "Pensiun" || $val['value'] == "Tujuan Usaha" ||$val['value'] == "Lain-lain" ){
					$content=str_replace("{insurance_purpose_jelaskan}",$val['value'],$content);
				} else {
					$content=str_replace("{insurance_purpose_jelaskan}","",$content);
				}
				
			}else{
				$val['value']=isset($val['value']) ? $val['value']:"";
				if($val['name'] == 'company_name2'){
					if($is_individu){
						//$fullname_company="";
						$content=str_replace("{fullname_company}","",$content);
						$content=str_replace("{company_name2}",$val['value'],$content);
					}else{
						$content=str_replace("{fullname_company}",$fullname_company,$content);
						$content=str_replace("{company_name2}",$val['value'],$content);
					}
				}else{
					$content=str_replace("{".$val['name']."}",$val['value'],$content);
				}
				//$content=str_replace("{".$val['name']."}",$val['value'],$content);
			}
			
			
				
			if($val['name']=="full_name1"){
				$full_name1=$val['value'];
				$fullname_company=$val['value'];	
			}
			if($val['name']=="full_name2"){
				$full_name2=$val['value'];	
			}
			if($val['name']=="premium_payer_name3"){
				$full_name3=$val['value'];	
			}
				
				
		}

		//* SPAJ JSON
		foreach($decode2 as $key2 => $val2){

			if($key2 == 'cpp_currency'){
				$holderCurrency=array(
				'IDR'=>'currency1',
				'USD'=>'currency2',
				''=>''
				);	
				$content=str_replace("{".$holderCurrency[$val2]."}","V",$content);
				unset($holderCurrency[$val2]);
				foreach($holderCurrency as $holderCurrency_key=>$holderCurrency_val){
					$content=str_replace("{".$holderCurrency_val."}","",$content);
				}	
				
			}
			
			if($key2 == 'cpp_premi'){
				$match = "/IDR/i";
				if(preg_match($match, $val2)){
					$pattern = '/IDR/i';
				} else {
					$pattern = '/USD/i';
				}
				$value 	 = preg_replace($pattern, "", $val2);

				$content=str_replace("{".$key2."}",$value,$content);
				// $content=str_replace("{".$key2."}",$val2,$content);				
			}
			
			if($key2 == 'cpp_periode'){
				$holderCurrency=array(
					'6 Bulan'=>'investment_period1',
					'12 Bulan'=>'investment_period2',
					''=>''
				);	
				$content=str_replace("{".$holderCurrency[$val2]."}","V",$content);
				unset($holderCurrency[$val2]);
				foreach($holderCurrency as $holderCurrency_key=>$holderCurrency_val){
					$content=str_replace("{".$holderCurrency_val."}","",$content);
				}	
				
			}
			
			if($key2 == 'cpp_mti_pa'){
				$pattern = '/%/i';
				$value 	 = preg_replace($pattern, "", $val2);

				$content=str_replace("{".$key2."}",$value,$content);
			}

			if($key2 == 'cpp_tgl_asu'){
				$date = explode(' ', $val2);

				$day = $date[0];

				$day = str_pad($day, 2, '0', STR_PAD_LEFT);

				$content=str_replace("{date_of_coverage_d}",$day,$content);
				$content=str_replace("{date_of_coverage_m}",$this->convertStringTonumberMonth($date[1]),$content);
				$content=str_replace("{date_of_coverage_y}",$date[2],$content);

				$content=str_replace("{signature_date_d}",$day,$content);
				$content=str_replace("{signature_date_m}",$this->convertStringTonumberMonth($date[1]),$content);
				$content=str_replace("{signature_date_y}",$date[2],$content);
			}

			if($key2 == 'cpp_no_spaj'){
				$content=str_replace("{".$key2."}",$val2,$content);				
			}

			
			// else {
				// $content=str_replace("{".$key2."}",$val2,$content);
			// }

		}
		
		$number 		  = '';
		$heirName 		  = '';
		$heirRelationship = '';
		$heirGender 	  = '';
		$heirDob1 		  = '';
		$heirDob2 		  = '';
		$heirDob3 		  = '';
		$pct 		  	  = '';

		//* AHLI WARIS
		$no = 1;
		foreach($decode3 as $key => $item){

			if($key <= 5){

				$leftName 		  = 76;
				$leftRelationship = 268;
				$leftGender 	  = 344.5;
				$leftDob1 		  = 417;
				$leftDob2 		  = 454;
				$leftDob3 		  = 489;
				$leftpct 		  = 544;
				$topPosition	  = 0;
	
				$dateOfBirth = explode('-', $item['tanggal_lahir']);
	
				$dob1 = $dateOfBirth[2];
				$dob2 = $dateOfBirth[1];
				$dob3 = $dateOfBirth[0];
	
				if($key <= 5){
					if($key == 0){
						$topPosition  = 302;
					} elseif($key == 1){
						$topPosition  = 313;
					} elseif($key == 2){
						$topPosition  = 324.5;
					} elseif($key == 3){
						$topPosition  = 335.5;
					} elseif($key == 4){
						$topPosition  = 346.4;
					} elseif($key == 5) {
						$topPosition  = 357.9;
					}
	
					$number.= '<div id="number_sequence" style="font-size: 10px; margin: 0pt; padding: 0pt; left: 54pt; top: '.$topPosition.'pt; position: absolute;">'.$no.'</div>';
					$heirName .= '<div id="heir_name" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftName.'pt; top: '.$topPosition.'pt; position: absolute;">'.$item['nama'].'</div>';
					$heirRelationship .= '<div id="heir_relationship" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftRelationship.'pt; top: '.$topPosition.'pt; position: absolute;">'.$item['hubungan'].'</div>';
					$heirGender .= '<div id="heir_gender" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftGender.'pt; top: '.$topPosition.'pt; position: absolute;">'.$item['jenis_kelamin'].'</div>';
					$heirDob1 .= '<div id="heir_date_of_birthr" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftDob1.'pt; top: '.$topPosition.'pt; position: absolute;">'.$dob1.'</div>';
					$heirDob2 .= '<div id="heir_date_of_birthr" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftDob2.'pt; top: '.$topPosition.'pt; position: absolute;">'.$dob2.'</div>';
					$heirDob3 .= '<div id="heir_date_of_birthr" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftDob3.'pt; top: '.$topPosition.'pt; position: absolute;">'.$dob3.'</div>';
					$pct .= '<div id="heir_date_of_birthr" style="font-size: 10px; margin: 0pt; padding: 0pt; left: '.$leftpct.'pt; top: '.$topPosition.'pt; position: absolute;">'.$item['pct'].'</div>';
	
				}
	
				$no++;
	
			}

		}

		$content=str_replace("{NUMBER}", $number, $content);
		$content=str_replace("{HEIRNAME}", $heirName, $content);
		$content=str_replace("{HEIRRELATIONSHIP}", $heirRelationship, $content);
		$content=str_replace("{HEIRGENDER}", $heirGender, $content);
		$content=str_replace("{DATEOFBIRTH1}", $heirDob1, $content);
		$content=str_replace("{DATEOFBIRTH2}", $heirDob2, $content);
		$content=str_replace("{DATEOFBIRTH3}", $heirDob3, $content);
		$content=str_replace("{PCT}", $pct, $content);
		
		$content=str_replace("{signature_place}",$rows['NAMA_AREA'], $content);
		

		$dompdf = new Dompdf();
		$content=str_replace("{IMG_BG}","data:image/png;base64,".base64_encode(file_get_contents(realpath(".")."/template/SPAJ_CPP_NEW-1.png")),$content);
		$content=str_replace("{IMG_BG2}","data:image/png;base64,".base64_encode(file_get_contents(realpath(".")."/template/SPAJ_CPP_NEW-2.png")),$content);
		
		include(realpath(".").'/application/libraries/phpqrcode/qrlib.php');
		
		//TTD PEMPOL
		ob_start();
		QRCode::png($rows['nama_pp']."|".$rows['spaj_code']."|".$rows['effective_dt'], null);
		$imageString_policy_holder_name_ttd = base64_encode( ob_get_contents() );
		ob_end_clean();
		
		//TTD TT
		ob_start();
		QRCode::png($rows['nama_tt']."|".$rows['spaj_code']."|".$rows['effective_dt'], null);
		$imageString_insured_name_ttd = base64_encode( ob_get_contents() );
		ob_end_clean();
		
		//TTD Payer
		ob_start();
		QRCode::png($full_name3."|".$rows['spaj_code']."|".$rows['effective_dt'], null);
		$imageString_payer_name_ttd = base64_encode( ob_get_contents() );
		ob_end_clean();
		
		//TTD PR
		ob_start();
		QRCode::png($rows['NAMA_RM']."|".$rows['spaj_code']."|".$rows['effective_dt'], null);
		$imageString_agen_reff_name_ttd = base64_encode( ob_get_contents() );
		ob_end_clean();
		
		//TTD AGEN 
		//$rows['pfa_desc']."|".$rows['spaj_code']."|".$rows['effective_dt']
		QRCode::png($rows['pfa_desc']."|".$rows['spaj_code']."|".$rows['effective_dt'], null);
		$imageString_agen_name_ttd = base64_encode( ob_get_contents() );
		ob_end_clean();
		
		//exit($rows['pfa_desc']."|".$rows['spaj_code']."|".$rows['effective_dt']);
		
		
		$content=str_replace("{policy_holder_name}",$rows['nama_pp'],$content);
		$content=str_replace("{insured_name}",$rows['nama_tt'],$content);
		$content=str_replace("{refferal_name}",$rows['NAMA_RM'],$content);
		$content=str_replace("{refferal_code}",$rows['KODE_RM'],$content);
		$content=str_replace("{pfa_name}",$rows['pfa_desc'],$content);
		$content=str_replace("{pfa_code}",$rows['kode_agen'],$content);
		
		
		
		$content=str_replace("{IMG_SIGNATURE_1}","data:image/png;base64,".$imageString_policy_holder_name_ttd,$content);
		$content=str_replace("{IMG_SIGNATURE_2}","data:image/png;base64,".$imageString_insured_name_ttd,$content);
		$content=str_replace("{IMG_SIGNATURE_3}","data:image/png;base64,".$imageString_payer_name_ttd,$content);
		$content=str_replace("{IMG_SIGNATURE_4}","data:image/png;base64,".$imageString_agen_reff_name_ttd,$content);
		$content=str_replace("{IMG_SIGNATURE_5}","data:image/png;base64,".$imageString_agen_name_ttd,$content);

		$dompdf->loadHtml($content);

		$sizePaper = array(0,0,610,955);
		$dompdf->setPaper($sizePaper, "portrait");
		$dompdf->render();
		$dompdf->stream("cpp_page1_new.pdf",array("Attachment"=>0));
	}
	
	
	
	public function cpp(){
		require_once(realpath(".").'/application/libraries/PDFMerger/PDFMerger.php');
		
		if($this->input->get("id",true)==""){
			exit;
		}
		
		$this->load->database();
		$str="select s.ID,s.trx_id,s.spaj_code,s.no_polis,s.product_code,s.nama_pp,s.effective_dt,s.last_change_dt,s.status_qc,
				DATE_FORMAT(s.last_change_dt,'%Y%m%d') as docdir from tbl_spaj s where s.ID=?";
		$query=$this->db->query($str,array(base64_decode($this->input->get("id",true))));
		$rows=$query->row_array();
		if(count($rows)<=0){
			echo"invalid access";
			exit;
		}
		
		$trx_id=$rows['docdir']."/".$rows['trx_id'];
		if(file_exists(realpath(".").'/xtemp/'.$rows['spaj_code'].'/'.$rows['spaj_code'].'.pdf')){
			redirect($this->config->item("api_outgoing_url")."/xtemp/".$rows['spaj_code'].'/'.$rows['spaj_code'].'.pdf?'.time());
			exit;
		}
		if($rows['product_code']=="CPP"){
			$this->cpp1();
			$this->cpp2();
		}else{
			$this->cpl1();
			$this->cpl2();
			$this->cpl3();
		}
		$files=scandir(realpath(".")."/xtemp/".$rows['spaj_code']);
		
		$pdf = new \PDFMerger;
		$arr=array();
		foreach($files as $f){
			if(!in_array($f,array('.','..'))){
				$arr[]=realpath(".").'/xtemp/'.$rows['spaj_code'].'/'.$f;
				$pdf->addPDF(realpath(".").'/xtemp/'.$rows['spaj_code'].'/'.$f);
			}
		}
		$pdf->merge('file', realpath(".").'/xtemp/'.$rows['spaj_code'].'/'.$rows['spaj_code'].'.pdf');
		
		foreach($arr as $a){
			@unlink($a);
		}
		
		redirect($this->config->item("api_outgoing_url")."/xtemp/".$rows['spaj_code'].'/'.$rows['spaj_code'].'.pdf?'.time());
	}
	
	public function cpp_spaj(){
		require_once(realpath(".").'/application/libraries/PDFMerger/PDFMerger.php');
		
		if($this->input->get("spaj_code")==""){
			exit;
		}
		
