";
*/
$str_product="select 
data.ID,data.trx_id,data.spaj_code,data.no_polis,data.product_code,
concat('(',(@row_number:=@row_number + 1),') ',data.nama_pp) as nama_pp,
data.effective_dt,
data.last_change_dt,
data.status_qc,
data.status_spaj 
from (
select 
s.ID,s.trx_id,s.spaj_code,ifnull(s.no_polis,'') as no_polis,s.product_code,
			nama_pp,
			effective_dt,DATE_FORMAT(last_change_dt,'%d %M %Y %H:%i %p') as last_change_dt,status_qc,
concat(case when ifnull(s.no_polis_reff,'')='' then 'New' else 'Exisisting' end,' | ',h.reason) as status_spaj,
 s.last_change_dt as last_change_dt_ori
from tbl_spaj_history h
join tbl_spaj s on s.spaj_code=h.spaj_code
where 1=1 
".($agen_code=="PFA009" ? "":" and (s.agen_code=? or s.pfa_code=?) ")." ".($date!="" ? " and cast(s.last_change_dt as date)='".$date."'":"")."
and (h.reason like'%take out%' or h.reason like'%unclean%'  or h.reason like'%pending%') 
and (h.reason not like'%Reply%' and h.reason not like'%Submit Dokumen%')
and s.inforce_dt is null
and s.spaj_code not like'%DEL%') as data";
			if($agen_code=="PFA009"){
				$query=$this->db->query($str_product);
			}else{
				$query=$this->db->query($str_product,array($agen_code,$agen_code));
			}

			$rows=$query->result_array();
			$count_row=count($rows);
			if($count_row>0){
				$message=array('error'=>0,'message'=>'success','data'=>$rows,'agen_code'=>$agen_code,'count'=>$count_row);
			}else{
				//$message=array('error'=>1,'message'=>'Failed');
				$message=array('error'=>0,'message'=>'success','data'=>array(),'agen_code'=>$agen_code,'count'=>0);
			}
		}
		echo json_encode($message);
	}
	
	public function spaj_surrender_pro(){
		if($_SERVER['REQUEST_METHOD']!=="POST") die("Invalid Request");
		$data=$this->input->post("data",true);
		$data=base64_decode($data);
		$data=json_decode($data,true);
		
		
		$agen_code=isset($data["agen_code"]) ? $data["agen_code"]:"";
		$no_spaj=isset($data["no_spaj"]) ? $data["no_spaj"]:"";
		$paid_date=isset($data["paid_date"]) ? $data["paid_date"]:"";
		$paid_date=$this->fix_human_date($paid_date);
		
		$message=array('error'=>1,'message'=>'Invalid Request');
		if($agen_code!=""){
			$this->load->database();
			$query=$this->db->query("call usp_spaj_surrender_confirmation_i(?,?,?,?)",array($no_spaj,$paid_date,$agen_code,'Cair'));
			if($query){
				$message=array('error'=>0,'message'=>'success');
			}else{
				//$message=array('error'=>1,'message'=>'Failed');
				$message=array('error'=>1,'message'=>'failed');
			}
		}
		echo json_encode($message);
	
	}
	public function spaj_surrender(){
		if($_SERVER['REQUEST_METHOD']!=="POST") die("Invalid Request");
		$data=$this->input->post("data",true);
		$data=base64_decode($data);
		$data=json_decode($data,true);
		
		
		$agen_code=isset($data["agen_code"]) ? $data["agen_code"]:"";
		$limit=isset($data["limit"]) ? $data["limit"]:"";
		$start_date=isset($data["start_date"]) ? $data["start_date"]:"";
		$end_date=isset($data["end_date"]) ? $data["end_date"]:"";
		$message=array('error'=>1,'message'=>'Invalid Request');
		if($agen_code!=""){
			$this->load->database();
			
			$this->db->query("SET @row_number:=0;");
			$str_product="
SELECT 
		
		b.ID as ID,
		p.policy_no as NO_POLIS,
		b.spaj_code as NO_SPAJ,
		concat('(',(@row_number:=@row_number + 1),') ',b.policy_holder_name) as NAMA_PEMPOL,
		b.product_name as NAMA_PRODUK,
		b.currency as KD_VALUTA,
		r.periode_pencairan as PERIODE_CAIR,
		DATE_FORMAT(r.periode_tgl_awal,'%d/%m/%Y') as TGL_MULAI_ASURANSI,	
		DATE_FORMAT(ss.polis_print_dt,'%d/%m/%Y') as TGL_CETAK_POLIS,
		DATE_FORMAT(h.start_date,'%d/%m/%Y') as TGL_MTI_AWAL,
		DATE_FORMAT(h.end_date,'%d/%m/%Y') as TGL_MTI_AKHIR,
DATE_FORMAT(h.end_date,'%d/%m/%Y') as TGL_JATUH_TEMPO,
DATE_FORMAT(r.periode_tgl_akhir,'%d/%m/%Y') as TGL_JATUH_TEMPO_AKHIR_PERIOD,	
replace(pp.rate_polis,'.',',') as RATE_BUNGA_SESUAI_POLIS,	
replace(cast((pp.rate_polis-r.rate_bunga) as decimal(4,2)),'.',',') as PINALTI_SURR,
		DATE_FORMAT(h.paid_date,'%d/%m/%Y') as TGL_BAYAR,
case when h.period=12 then 
concat('MATURITY-KLAIM BUNGA INVESTASI (',h.period,'/',r.periode_pencairan,')')
when b.product_name in('Asuransi Capital Proteksi Link (3/6 bulan)') and h.period=r.periode_pencairan then 
concat('MATURITY-KLAIM BUNGA INVESTASI (',h.period,'/',r.periode_pencairan,')')
when h.period=r.periode_pencairan then 
concat('SURRENDER-KLAIM BUNGA INVESTASI (',h.period,'/',r.periode_pencairan,')') 
else 
concat('KLAIM BUNGA INVESTASI (',h.period,'/',r.periode_pencairan,')')
end as JENIS_TRANSAKSI,
		replace(r.rate_bunga,'.',',') as RATE_BUNGA,
		replace(r.premi,'.',',') as PREMI,
		replace(h.mti_amount+h.adjust_mti_amount,'.',',') as BUNGA_MTI,
		replace((h.total_paid_amount),'.',',') as TOTAL_BAYAR,
		r.jumlah_hari_setahun as JML_HARI_SETAHUN,
		(h.day_count+coalesce(h.adjust_day_count,0)) as JML_HARI_MTI,
		(r.jumlah_hari_mti+coalesce(h.adjust_day_count,0)) as JML_HARI_MTI_SAMPAI_AKHIR_PERIOD,
		b.agen_reff_code as KD_AGEN_REFF,
		b.agen_reff_name as NAMA_AGEN_REFF,
		b.branch_reff_code as KD_CABANG,
		b.branch_reff_name as NAMA_CABANG,
		b.agen_level as AGEN_REFF_LEVEL,
		b.cluster_code as NAMA_CLUSTER,
		b.pfa as PIC_CLI,
		b.bbc_code as KD_BBC,
		b.bbc_name as NAMA_BBC,
		b.bm_code as KD_BM,
		b.bm_name as NAMA_BM,
		b.bbh_code as KD_BBH,
		b.bbh_name as NAMA_BBH,
		datediff(NOW(),h.end_date) as AGING,
		pp.NAMA_BANK,	
concat('`',pp.NOMOR_REKENING) NOMOR_REKENING,
pp.PEMILIK_REKENING,	
pp.BANK_CABANG,
DATE_FORMAT(ms.status_dt,'%d/%m/%Y') as TGL_UPLOAD_FORM_SURRENDER,
DATE_FORMAT(pfa.create_date,'%d/%m/%Y') as TGL_MS_CONFIRM_FORM_SURRENDER,
coalesce(concat(ee.remarks,', tgl konfirmasi :',DATE_FORMAT(ee.create_dt,'%d/%m/%Y')),'') as KOFIRMASI_SURRENDER
		FROM `tbl_spaj_book` b
		join tbl_spaj_book_reference r on b.ID=r.book_id and trim(r.spaj_code)=trim(b.spaj_code)
		join tbl_spaj_book_reference_hst h on b.ID=h.book_id and r.book_id=h.book_id
                left join tbl_spaj_pending p on trim(p.span_no)=trim(r.spaj_code) and trim(p.span_no)=trim(b.spaj_code) and h.spaj_code=p.span_no and p.source_id='100'
left join tbl_policy_promo pp on pp.spaj_code=b.spaj_code and pp.spaj_code=h.spaj_code and cast(pp.periode_tgl_awal as date)=cast(r.periode_tgl_awal as date)
left join tbl_spaj ss on ss.spaj_code=b.spaj_code and ss.spaj_code=r.spaj_code and ss.spaj_code=h.spaj_code and trim(p.span_no)=ss.spaj_code
left join (select spaj_code,max(status_dt) as status_dt from tbl_spaj_history where status_type_nmbr='600' group by spaj_code) ms on ms.spaj_code=b.spaj_code and ms.spaj_code=r.spaj_code and ms.spaj_code=h.spaj_code and ms.spaj_code=p.span_no		
left join (select spaj_code,max(create_date) as create_date from tbl_spaj_doc where doc_type_nmbr='D043' group by spaj_code) pfa on pfa.spaj_code=b.spaj_code and pfa.spaj_code=r.spaj_code and pfa.spaj_code=h.spaj_code and pfa.spaj_code=p.span_no		
left join tbl_spaj_surrender_confirmation ee on ee.spaj_code=h.spaj_code and ee.paid_date=h.paid_date
		WHERE trim(b.`product_name`) in(
            'CAPITAL PROTEKSI PLUS (IDR) (1/12b bulan)',
            'CAPITAL PROTEKSI PLUS (IDR) (3/12 bulan)',
            'CAPITAL PROTEKSI PLUS (USD) (3/12 bulan)',
            'Asuransi Capital Proteksi Link (3/6 bulan)'
            )
		and b.reverse_date is null and b.issued_date is not null
		and b.cluster_code in(
SELECT cluster
FROM `tbl_bank_data_ms`
WHERE `PIC_CLI` LIKE concat('%',(select pfa_desc from tbl_pfa where pfa_code='".$agen_code."' limit 1),'%')
group by cluster
)
	and cast(h.paid_date as date) between ? and ?
";
			$query=$this->db->query($str_product,array($start_date,$end_date));

			$rows=$query->result_array();
			$count_row=count($rows);
			if($count_row>0){
				$message=array('error'=>0,'message'=>'success','data'=>$rows,'agen_code'=>$agen_code,'count'=>$count_row);
			}else{
				//$message=array('error'=>1,'message'=>'Failed');
				$message=array('error'=>0,'message'=>'success','data'=>array(),'agen_code'=>$agen_code,'count'=>0);
			}
		}
		echo json_encode($message);
	}
	
	public function spaj(){
		if($_SERVER['REQUEST_METHOD']!=="POST") die("Invalid Request");
		$data=$this->input->post("data",true);
		$data=base64_decode($data);
		$data=json_decode($data,true);
		
		$agen_code=isset($data["agen_code"]) ? $data["agen_code"]:"";
		$limit=isset($data["limit"]) ? $data["limit"]:"";
		$date=isset($data["date"]) ? $data["date"]:"";
		$policy_no=isset($data["policy_no"]) ? $data["policy_no"]:"";
		$fullname=isset($data["fullname"]) ? $data["fullname"]:"";
		$message=array('error'=>1,'message'=>'Invalid Request');
		$wh_agen="";
		
		/*if($agen_code!="PFA009"){
			$limit=($date!="" ? "150":"50");
		}*/
		$limit=($date!="" ? "150":"50");
		
		if($agen_code!=""){
			if($agen_code!="PFA009"){
				$wh_agen=" AND (s.agen_code='$agen_code' or s.pfa_code='$agen_code') ";
			}
			
			$this->load->database();
			//SET @row_number = 0;
			//concat('(',(@row_number:=@row_number + 1),') ',nama_pp) as nama_pp,
			$this->db->query("SET @row_number:=0;");
			$str_product="
			SELECT  ID,trx_id,spaj_code,ifnull(no_polis,'') as no_polis,product_code,
			concat('(',(@row_number:=@row_number + 1),') ',nama_pp) as nama_pp,
			effective_dt,DATE_FORMAT(last_change_dt,'%d %M %Y %H:%i %p') as last_change_dt,status_qc,
/*
concat(case when ifnull(s.no_polis_reff,'')='' then 'New' else 'Exisisting' end,' | ',(select reason from tbl_spaj_history where ID=s.ID order by status_dt desc  limit 1)) as status_spaj,s.no_polis */

concat(case when ifnull(s.no_polis_reff,'')='' then 'New' else 'Existing' end,' | ','') as status_spaj,s.no_polis
						FROM tbl_spaj s
						WHERE 1=1  ".$wh_agen."
						".($date!="" ? " and cast(s.last_change_dt as date)='".$date."'":"")." 
						
						".($policy_no!="" ? " and (s.spaj_code='".$policy_no."' or s.no_polis='".$policy_no."')":"")." 
						".(($fullname!="" and strlen($fullname)>=4) ? " and ( s.nama_pp like'%".$fullname."%' )":"")." 
						
						ORDER BY s.last_change_dt DESC ".($limit=="" ? "":"limit ".$limit).";";
						//".($policy_no!="" ? " and (s.spaj_code='".$policy_no."' or s.no_polis='".$policy_no."')":"")." 
						
			$query=$this->db->query($str_product,array($agen_code,$agen_code));
			$rows=$query->result_array();
			
			
			
			if(count($rows)>0){
				$message=array('error'=>0,'message'=>'success','data'=>$rows);
			}else{
				$message=array('error'=>1,'message'=>'Failed');
			}
		}
		echo json_encode($message);
	}
	
	public function spajpr(){
		if($_SERVER['REQUEST_METHOD']!=="POST") die("Invalid Request");
		$data=$this->input->post("data",true);
		$data=base64_decode($data);
		$data=json_decode($data,true);
		
		$agen_code=isset($data["agen_code"]) ? $data["agen_code"]:"";
		$limit=isset($data["limit"]) ? $data["limit"]:"";
		$fullname=isset($data["fullname"]) ? $data["fullname"]:"";
		$message=array('error'=>1,'message'=>'Invalid Request');
		$wh_agen="";
		
		if($agen_code!=""){
			$this->load->database();
			$this->db->query("SET @row_number:=0;");
			$str_product="
			select 
(@row_number:=@row_number + 1) as No,ticket_id,a.agen_name,d.agen_code_request,d.spaj_code,d.client_name,d.client_insured_name,d.product_name,d.create_date,
concat(fnAmountIndo(d.premium),' (',d.product_name,' (',d.invesment_period,'))') as premium,fnDateIndo(d.tanggal_masuk) as tanggal_masuk,
d.product_name as ori_product,
d.invesment_period as ori_period,
#replace(fnAmountIndo(d.premium),',','') as ori_premi,
replace(replace(replace(fnAmountIndo(d.premium),'.','|'),',','.'),'|',',') as ori_premi,
cast(d.tanggal_masuk as date) as ori_tgl_masuk,
(select group_concat(concat(dx.doc_path,'|',t.doc_name))
from tbl_agen_pengajuan_bisnis_doc dx
join tbl_agen_pengajuan_bisnis_doc_type t on t.doc_type=dx.doc_type
where dx.ticket_id=d.ticket_id) as document_name,
ifnull((select KODE_CAB from tbl_bank_data_ms where KODE_RM=d.agen_code_request limit 1),'') as branch_code,
ifnull(d.no_slip,'-') as no_slip,
case when coalesce(d.dob_ctu,'1900-01-01')='1900-01-01' then '-' else fnDateIndo(d.dob_ctu) end as dob_ctu_indo,
cast(d.dob_ctu as date) as dob_ctu_ori,
ifnull(d.jenis_nasabah,'-') as jenis_nasabah,
ifnull(d.konfirmasi_pakai_data_cli,'-') as konfirmasi_pakai_data_cli,
ifnull(d.alasan_pengajuan,'-') as alasan_pengajuan,
(select concat('Cab: ',NAMA_CABANG,'<br>BBC: ',CLUSTER) from tbl_bank_data_ms where KODE_RM=d.agen_code_request limit 1) as cabang
from tbl_agen_pengajuan_bisnis d 
left join tbl_spaj s on s.spaj_code=d.spaj_code
join tbl_agen a on a.agen_code=d.agen_code_request
where coalesce(d.is_submited,0)=1 and agen_code_request in(select KODE_RM from tbl_bank_data_ms where pfa_desc='$agen_code')
and s.spaj_code is null
and coalesce(d.reject_status,0)=0
order by d.tanggal_masuk,d.create_date asc";
						
						
			$query=$this->db->query($str_product,array($agen_code,$agen_code));
			$rows=$query->result_array();
			
			
			
			if(count($rows)>0){
				$message=array('error'=>0,'message'=>'success','data'=>$rows);
			}else{
				$message=array('error'=>1,'message'=>'Failed');
			}
		}
		echo json_encode($message);
	}
	
	public function spajpr_doc(){
		if($_SERVER['REQUEST_METHOD']!=="POST") die("Invalid Request");
		$data=$this->input->post("data",true);
		$data=base64_decode($data);
		$data=json_decode($data,true);
		
		$agen_code=isset($data["agen_code"]) ? $data["agen_code"]:"";
		$no_ticket=isset($data["no_ticket"]) ? $data["no_ticket"]:"";
		
		$message=array('error'=>1,'message'=>'Invalid Request');
		$wh_agen="";
		
		if($agen_code!=""){
			$this->load->database();
			$str_product="
			select 
			dx.doc_path,
			t.doc_name,
			dx.doc_type
			from tbl_agen_pengajuan_bisnis d 
			left join tbl_spaj s on s.spaj_code=d.spaj_code
			join tbl_agen a on a.agen_code=d.agen_code_request
			join tbl_agen_pengajuan_bisnis_doc dx on dx.ticket_id=d.ticket_id
			join tbl_agen_pengajuan_bisnis_doc_type t on t.doc_type=dx.doc_type
			where coalesce(d.is_submited,0)=1 and d.ticket_id='".$no_ticket."'
			order by t.sort_order asc";
						
						
			$query=$this->db->query($str_product);
			$rows=$query->result_array();
			
			
			
			if(count($rows)>0){
				$message=array('error'=>0,'message'=>'success','data'=>$rows);
			}else{
				$message=array('error'=>1,'message'=>'Failed');
			}
		}
		echo json_encode($message);
	}
	
	public function spaj_detail(){
		error_reporting(0);
		$message=array('error'=>1,'message'=>'Invalid Request');
		$product_code="";
		$trx_idx="";
		$spaj_id="";
		$spaj_code="";
		if($_SERVER['REQUEST_METHOD']!=="POST"){
			$message=array('error'=>1,'message'=>'Invalid Request Method');
		}else{
			$cases=$this->input->post("data",true);
			$cases=base64_decode($cases);
			$cases=json_decode($cases,true);
			$agen_code=isset($cases['agen_code']) ? $cases['agen_code']:"";
			$id=isset($cases['id']) ? $cases['id']:"";
			$trx_id="";
			try{
				$this->load->database();
				
				$str_product="SELECT
				e.spaj_code as spaj_code_exclude,
				h.status_type_nmbr,
				#'' as status_type_nmbr,
				s.ID,s.trx_id,s.spaj_code,s.no_polis,s.product_code,s.nama_pp,s.effective_dt,s.last_change_dt,s.status_qc,
				DATE_FORMAT(s.last_change_dt,'%Y%m%d') as docdir,concat(a.intermediary_name,' Cabang : ',cab.NAMA_CABANG,' - ',a.cluster) as nama_referal,concat(f.nama_agen,' (',f.kode_agen,')') as nama_agen_penutup,s.product_code
							FROM tbl_spaj s
left join (
(select 
		kode_bbc as intermediary_code, 
		concat(nama_bbc,' (',kode_bbc,')') as intermediary_name,min(pic_cli) as pic_cli,min(cluster) as cluster,'bbc' as level,min(KODE_CAB) as KODE_CAB,min(NAMA_CABANG) as NAMA_CABANG
		from tbl_bank_data_ms group by kode_bbc,nama_bbc)
union		
(select 
		kode_bm as intermediary_code, 
		concat(nama_bm,' (',kode_bm,')') as intermediary_name,min(pic_cli) as pic_cli,min(cluster) as cluster,'bm' as level,min(KODE_CAB) as KODE_CAB,min(NAMA_CABANG) as NAMA_CABANG
		from tbl_bank_data_ms group by kode_bm,nama_bm)
union		
(select 
		kode_rm as intermediary_code, 
		concat(nama_rm,' (',kode_rm,')') as intermediary_name,pic_cli,cluster,LEVEL_AGEN as level,KODE_CAB,NAMA_CABANG
		from tbl_bank_data_ms)) a on a.intermediary_code=s.agen_code 
join tbl_pfa f on f.pfa_code=s.pfa_code
left join tbl_spaj_edit_exclude e on e.spaj_code=s.spaj_code and now() between e.start_date and e.end_date
left join (select KODE_CAB,NAMA_CABANG from tbl_bank_data_ms group by KODE_CAB,NAMA_CABANG) cab on cab.KODE_CAB=s.branch_code

left join (select h.spaj_code,h.status_type_nmbr,h.reason from tbl_spaj_history h
join (
select spaj_code,max(status_dt) as status_dt 
from tbl_spaj_history  where status_type_nmbr not in('201','202','203','220','400','410','420','430')
group by spaj_code) a on h.spaj_code=a.spaj_code and a.status_dt=h.status_dt) h on s.spaj_code=h.spaj_code

							WHERE s.ID=?";
				$query=$this->db->query($str_product,array($id));
				$rows=$query->row_array();
				$product_code=$rows['product_code'];
				$trx_idx=$rows['trx_id'];
				$spaj_id=$rows['ID'];
				$spaj_code=$rows['spaj_code'];
				$trx_id=$rows['docdir']."/".$rows['trx_id'];


				
				
				$str_status="select ID,status_type_nmbr,spaj_code,reason,DATE_FORMAT(l.status_dt,'%d %M %Y %H:%i %p') as status_dt from tbl_spaj_history l where ID=? order by l.status_dt desc";
				$query_status=$this->db->query($str_status,array($id));
				$rows_status=$query_status->result_array();
				
				$str_doclist="
				select t.doc_type_desc,d.path from tbl_spaj s
				join tbl_spaj_doc d on d.spaj_code=s.spaj_code
				join tbl_doc_type t on d.doc_type_nmbr=t.doc_type_nmbr
				where s.ID=?
				";
				$query_doclist=$this->db->query($str_doclist,array($id));
				$rows_doclist=$query_doclist->result_array();
				
				
				$str_doclist_pr="
				select t.doc_name,d.doc_path,coalesce(b.no_slip,s.payment_remarks) as no_slip from tbl_spaj s
				left join tbl_agen_pengajuan_bisnis b on b.spaj_code=s.spaj_code
				left join tbl_agen_pengajuan_bisnis_doc d on d.ticket_id=b.ticket_id
				left join tbl_agen_pengajuan_bisnis_doc_type t on t.doc_type=d.doc_type
				where s.ID=?
				order by d.create_date asc
				";
				$query_doclist_pr=$this->db->query($str_doclist_pr,array($id));
				$rows_doclist_pr=$query_doclist_pr->result_array();
				
				

				//get jt promo
				$query_jt_promo=$this->db->query("select date_format(surrender_date,'%d/%m/%Y') as surrender_date from tbl_spaj_book_reference 
				where spaj_code='".$spaj_code."'");
				$rowsjt=$query_jt_promo->row_array();
				$rowsjt['surrender_date']=(isset($rowsjt['surrender_date']) ? $rowsjt['surrender_date']:"");
				
				
			}catch(Exception $er){
				
