	public function data_doc_ilustrasi(){
				$this->load->database();
				
				$id=$this->input->post("spaj_code");
				
				if($_SERVER['REQUEST_METHOD']!=="POST"){
				 exit;
				}
				
				$str_product="SELECT     s.ID,s.trx_id,s.spaj_code,s.no_polis,s.product_code,s.nama_pp,s.effective_dt,s.last_change_dt,s.status_qc,
				DATE_FORMAT(s.last_change_dt,'%Y%m%d') as docdir,concat(a.intermediary_name,' Cabang : ',cab.NAMA_CABANG,' - ',a.cluster) as nama_referal,concat(f.nama_agen,' (',f.kode_agen,')') as nama_agen_penutup,s.product_code,s.agen_code,s.pfa_code
							FROM tbl_spaj s
join (
(select 
		kode_bbc as intermediary_code, 
		concat(nama_bbc,' (',kode_bbc,')') as intermediary_name,min(pic_cli) as pic_cli,min(cluster) as cluster,'bbc' as level,min(KODE_CAB) as KODE_CAB,min(NAMA_CABANG) as NAMA_CABANG
		from tbl_bank_data_ms group by kode_bbc,nama_bbc)
union		
(select 
		kode_bm as intermediary_code, 
		concat(nama_bm,' (',kode_bm,')') as intermediary_name,min(pic_cli) as pic_cli,min(cluster) as cluster,'bm' as level,min(KODE_CAB) as KODE_CAB,min(NAMA_CABANG) as NAMA_CABANG
		from tbl_bank_data_ms group by kode_bm,nama_bm)
union		
(select 
		kode_rm as intermediary_code, 
		concat(nama_rm,' (',kode_rm,')') as intermediary_name,pic_cli,cluster,LEVEL_AGEN as level,KODE_CAB,NAMA_CABANG
		from tbl_bank_data_ms)) a on a.intermediary_code=s.agen_code 
join tbl_pfa f on f.pfa_code=s.pfa_code
left join (select KODE_CAB,NAMA_CABANG from tbl_bank_data_ms group by KODE_CAB,NAMA_CABANG) cab on cab.KODE_CAB=s.branch_code
							WHERE s.spaj_code=?";
				$query=$this->db->query($str_product,array($id));
				$rows=$query->row_array();
				$product_code=$rows['product_code'];
				$trx_idx=$rows['trx_id'];
				$spaj_id=$rows['ID'];
				$spaj_code=$rows['spaj_code'];
				$trx_id=$rows['docdir']."/".$rows['trx_id'];
				$json=json_decode($this->other_doc($trx_id,"SPAJ"),true);
				//echo"<pre>";
				//print_r($json);
				/*
				CPP
				[cpp_no_spaj] => PP11235870
				[cpp_nama_pp] => INDRA GUNAWAN
				[cpp_nama_tt] => INDRA GUNAWAN
				[cpp_tgl_asu] => 25 Oktober 2021
				[cpp_dbo] => 2 Agustus 1962
				[cpp_age] => 59 Tahun
				[cpp_premi] => 250.000.000,00 IDR
				[cpp_periode] => 12 Bulan
				[cpp_currency] => IDR
				[cpp_promo_bunga]
				
				CPL
				[No_SPAJ] => PL04233150
				[Nama_Pemegang_Polis] => YENNY HOO
				[Nama_Tertanggung] => YENNY HOO
				[Tanggal_Lahir] => 28 Desember 1961
				[Usia_Tertanggung] => 60 Tahun
				[Tanggal_Mulai_Pertanggungan] => 25 Oktober 2021
				[Masa_Pertanggungan] => 10 (Sepuluh) Tahun
				[Uang_Pertanggungan] => 25.000.000,00 IDR
				[Premi] => 2.425.000.000,00 IDR
				[Premi_Sekaligus] => 20.000.000,00 IDR
				[Premi_Top_Up_Sekaligus] => 2.405.000.000,00 IDR
				[Masa_Target_Investasi] => 6 Bulan
				[Tingkat_Target_Investasi] => 5,00 %
				[Tanggal_Awal_MTI] => 25 Oktober 2021
				[Tanggal_Jatuh_Tempo_MTI] => 25 April 2022
				[Jenis_Dana_Investasi] => Capital Managed Fund
				[Alokasi_Premi] => 100 %
				[Mata_Uang] => IDR
				[Program_Relaksasi] => 
				*/
				$json['Program_Relaksasi']=isset($json['Program_Relaksasi']) ? $json['Program_Relaksasi']:"";
				
				if($rows['product_code']=="CPL"){
					echo json_encode(array(
					"no_spaj"=>$json['No_SPAJ'],
					"nama_pp"=>$json['Nama_Pemegang_Polis'],
					"nama_tt"=>$json['Nama_Tertanggung'],
					"tgl_asu"=>$this->fix_doc_date($json['Tanggal_Mulai_Pertanggungan']),
					"dbo"=>$this->fix_doc_date($json['Tanggal_Lahir']),
					"premi"=>$this->fix_doc_premi($json['Premi']),
					"periode"=>$this->fix_doc_mgi($json['Masa_Target_Investasi']),
					"currency"=>$json['Mata_Uang'],
					"promo_bunga"=>$json['Program_Relaksasi'],
					"trx_id"=>$rows['trx_id'],
					"filename"=>$this->doc_filename,
					"docdir"=>$rows['docdir'],
					"id"=>$rows['ID'],
					"agen_code"=>$rows['agen_code'],
					"pfa_code"=>$rows['pfa_code']
					));
				}else{
					echo json_encode(array(
					"no_spaj"=>$json['cpp_no_spaj'],
					"nama_pp"=>$json['cpp_nama_pp'],
					"nama_tt"=>$json['cpp_nama_tt'],
					"tgl_asu"=>$this->fix_doc_date($json['cpp_tgl_asu']),
					"dbo"=>$this->fix_doc_date($json['cpp_dbo']),
					"premi"=>$this->fix_doc_premi($json['cpp_premi']),
					"periode"=>$this->fix_doc_mgi($json['cpp_periode']),
					"currency"=>$json['cpp_currency'],
					"promo_bunga"=>$json['cpp_promo_bunga'],
					"trx_id"=>$rows['trx_id'],
					"filename"=>$this->doc_filename,
					"docdir"=>$rows['docdir'],
					"id"=>$rows['ID'],
					"agen_code"=>$rows['agen_code'],
					"pfa_code"=>$rows['pfa_code']
					));

				}
	}
	
	private function fix_doc_date($str){
		$str=explode(" ",$str);
		$arr_bulan=array(
		'Januari'=>'01',
		'Februari'=>'02',
		'Maret'=>'03',
		'April'=>'04',
		'Mei'=>'05',
		'Juni'=>'06',
		'Juli'=>'07',
		'Agustus'=>'08',
		'September'=>'09',
		'Oktober'=>'10',
		'November'=>'11',
		'Desember'=>'12'	
		);
		return $str[2]."-".$arr_bulan[$str[1]]."-".((int)$str[0]<=9 ? "0".$str[0]:$str[0]);
	}
	
	private function fix_doc_premi($str){
		$str=str_replace("IDR","",$str);
		$str=str_replace("USD","",$str);
		$str=str_replace(".","",$str);
		$str=str_replace(",",".",$str);
		return rtrim(ltrim($str));
		
	}
	
	private function fix_doc_mgi($str){
		$str=str_replace(" Bulan","",$str);
		$str=(int)rtrim(ltrim($str));
		return ($str<=6 ? "0":"1");
	}
	
	public function message_chat(){
		$message=array('error'=>1,'message'=>'Invalid Request');
		
		if($_SERVER['REQUEST_METHOD']!=="POST"){
			$message=array('error'=>1,'message'=>'Invalid Request Method');
		}else{		
			$cases=$this->input->post("data",true);
			$cases=base64_decode($cases);
			$cases=json_decode($cases,true);
			
			if(!is_array($cases)){
				$message=array('error'=>1,'message'=>'Invalid information.');
			}else{
				$agen_code=isset($cases['agen_code']) ? $cases['agen_code']:"";
				$msg=isset($cases['message']) ? $cases['message']:"";
				$id=isset($cases['id']) ? $cases['id']:"";
				if($agen_code=="" or $msg=="" or $id==""){
					$message=array('error'=>1,'message'=>'Invalid information.');
				}else{
					
					try{
						$this->load->database();
						$query=$this->db->query("call usp_message_chat(?,?,?)",array($agen_code,$msg,$id));
						$row=$query->row_array();
						$message=array('error'=>$row['error'],'message'=>$row['message']);
					}catch(Exception $e){
						$message=array('error'=>1,'message'=>'error. cause of: '.$e->getMessage());
					}
					
				}
			}
		}
		echo json_encode($message);
	}
	
	private function doclist($q){
		$dir=realpath(".")."/submission/".$q;
		
		$arr=array();
		if (is_dir($dir)){
		  if ($dh = opendir($dir)){
			while (($file = readdir($dh)) !== false){
			  $split=explode("_",$file);
			  if($file!="." && $file!=".." && $split[0]!="Thumbs.db" && $split[0]!="Cart"){
				
				$arr[$split[0]]=$file;
			  }
			}
			closedir($dh);
		  }
		}
		return $arr;
	}
	private function other_doc($q,$type){
		$dir=realpath(".")."/submission/".$q;
		
		$arr="";
		if (is_dir($dir)){
		  if ($dh = opendir($dir)){
			while (($file = readdir($dh)) !== false){
			  $split=explode("_",$file);
			  if($split[0]==$type){
				$this->doc_filename=$file;
				$this->doc_filename_arr[$type]=$file;
				$arr=file_get_contents($dir."/".$file);
			  }
			}
			closedir($dh);
		  }
		}
		return $arr;
	}
	
